# Default text normalization
* text=auto

# Source and documentation files
*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

# Fortran sources
*.f text eol=lf
*.for text eol=lf
*.f90 text eol=lf
*.F90 text eol=lf

# Unified model data is managed by Git LFS.
data/** filter=lfs diff=lfs merge=lfs -text

# Native binaries and binary assets should not be line-normalized.
*.dll binary
*.a binary
*.o binary
*.obj binary
*.so binary
*.dylib binary
*.lib binary
*.exp binary
*.pdb binary
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.zip binary
*.tar binary
*.tgz binary
*.gz binary
